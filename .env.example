# Public browser configuration. These values are embedded into the web build.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_ADMIN_PIN=change-this-pin

# Private server/worker configuration. Never commit real values.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Use the printer's fixed LAN address for Docker Desktop deployments.
PRINTER_HOST=192.168.1.131
PRINTER_PORT=9100
PRINT_BRIDGE_HEALTH_PORT=3101
